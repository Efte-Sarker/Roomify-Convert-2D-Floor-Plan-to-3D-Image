# Copy to server/.env and adjust for your XAMPP MySQL setup.

# Use 127.0.0.1 on Windows/XAMPP if localhost hits the wrong MySQL (IPv6 / different instance)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=roomify

# API server
PORT=3001

# JWT signing secret (required in production)
JWT_SECRET=change-me-in-production

# Browser origins allowed to use credentials (comma-separated)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cookie flag: secure=true requires HTTPS (auto-true when NODE_ENV=production)
# COOKIE_SECURE=false

# Optional: Gemini image generation (see server/routes/render.js)
# GEMINI_API_KEY=
