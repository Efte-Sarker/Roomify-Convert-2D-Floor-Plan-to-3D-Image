{
  "name": "roomify",
  "private": true,
  "type": "module",
  "scripts": {
    "server": "node server/index.js",
    "client:install": "cd client && npm install",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "dev:full": "concurrently -n client,api -c blue,green \"npm run client:dev\" \"npm run server\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0"
  }
}
